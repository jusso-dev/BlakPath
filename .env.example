# BlakPath environment configuration — copy to .env and fill in.
# NEVER commit a real .env. Secrets in production come from a secret manager
# (e.g. AWS Secrets Manager / KMS), not from this file.

NODE_ENV=development
APP_URL=http://localhost:3000
APP_REGION=ap-southeast-2

# --- Database ---
DATABASE_URL=postgres://blakpath:blakpath@localhost:5432/blakpath
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Better Auth ---
# Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# --- Application-level envelope encryption ---
# Generate: openssl rand -base64 32   (32 raw bytes -> 44 base64 chars)
ENCRYPTION_MASTER_KEY=replace-me-base64-encoded-32-byte-key========
ENCRYPTION_KEY_VERSION=1

# --- Object storage (MinIO locally, AWS S3 ap-southeast-2 in production) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-2
S3_ACCESS_KEY_ID=blakpath
S3_SECRET_ACCESS_KEY=blakpath-dev-secret
# Production only: customer-managed KMS key ARN. Leave the access-key pair
# above unset in production so the AWS SDK uses the workload role.
# S3_KMS_KEY_ID=arn:aws:kms:ap-southeast-2:123456789012:key/uuid
S3_BUCKET_EVIDENCE=blakpath-evidence
S3_BUCKET_QUARANTINE=blakpath-quarantine
S3_FORCE_PATH_STYLE=true

# --- ClamAV (malware scanning) ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Email (Mailpit locally) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=BlakPath <no-reply@blakpath.local>

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=blakpath
LOG_LEVEL=info

# --- Background scheduler ---
# Intervals are milliseconds. Schedulers reconcile active organisations every
# five minutes, and BullMQ persists the actual schedule in Redis.
AUDIT_VERIFY_INTERVAL_MS=86400000
RETENTION_SWEEP_INTERVAL_MS=86400000
SCHEDULER_SYNC_INTERVAL_MS=300000

# --- Feature toggles ---
# AI is OFF by default and must never be able to decide, score or infer identity.
AI_FEATURES_ENABLED=false
