# syntax=docker/dockerfile:1.7

###############################################################################
# BlakPath development image.
#
# Used by docker-compose.yml for hot-reload development. The host source tree is
# bind-mounted over /app, so this image only needs the toolchain (pnpm + tsx)
# and container-local node_modules. NOT for production — see Dockerfile.
###############################################################################

ARG NODE_VERSION=20.18.1
FROM node:${NODE_VERSION}-slim

ENV PNPM_HOME=/pnpm
ENV PATH="${PNPM_HOME}:${PATH}"
ENV NEXT_TELEMETRY_DISABLED=1

# tini for signal handling; curl for compose healthchecks; procps for pgrep.
RUN apt-get update \
  && apt-get install -y --no-install-recommends tini curl ca-certificates procps \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /app

# Prime the dependency cache. The compose bind-mount overlays source at runtime,
# but a named volume keeps /app/node_modules from being shadowed by the host.
COPY package.json pnpm-lock.yaml ./
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
  pnpm install --frozen-lockfile

# Run as the stock non-root `node` user shipped in the base image.
RUN chown -R node:node /app
USER node

EXPOSE 3000

ENTRYPOINT ["/usr/bin/tini", "--"]
# Default command is overridden per-service in docker-compose.yml
# (web -> pnpm dev, worker -> pnpm worker:dev).
CMD ["pnpm", "dev"]
